# ============================================
# E-Commerce Application Environment Variables
# ============================================
# Copy this file to .env and adjust as needed:
#   cp .env.example .env
#
# docker-compose.yml references these variables with ${VAR:-default} syntax.
# If a variable is not set here, the default value after :- is used.
# ============================================

# MySQL Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=full-stack-ecommerce
MYSQL_USER=ecommerceapp
MYSQL_PASSWORD=ecommerceapp
